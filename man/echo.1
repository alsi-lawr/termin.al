.\" termin.al-name: echo
.\" termin.al-usage: echo [text ...]
.\" termin.al-summary: Print arguments as text.
.TH ECHO 1 "" "termin.al" "termin.al Manual"
.ftr B R
.ftr I R
.ftr BI R
.SH NAME
echo \- Print arguments as text.
.SH SYNOPSIS
.nf
echo [text ...]
.fi
.SH DESCRIPTION
Joins its arguments with single spaces and writes the result to terminal scrollback.
.SH EXAMPLES
.nf
$ echo 'hello terminal'
.fi
.SH SEE ALSO
help(1), man(1)
