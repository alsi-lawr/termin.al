.\" termin.al-name: ls
.\" termin.al-usage: ls [-a] [-l] [--tree] [path]
.\" termin.al-summary: List virtual files and directories.
.TH LS 1 "" "termin.al" "termin.al Manual"
.ftr B R
.ftr I R
.ftr BI R
.SH NAME
ls \- List virtual files and directories.
.SH SYNOPSIS
.nf
ls [-a] [-l] [--tree] [path]
.fi
.SH DESCRIPTION
Lists entries in the current or selected virtual directory. Output is drawn from termin.al's read-only content tree; it does not inspect the host filesystem.
.SH OPTIONS
.TP
.B -a
Include hidden entries.
.TP
.B -l
Use the long listing with type, size and timestamp.
.TP
.B --tree
Render the selected directory as a tree; this cannot be combined with -l.
.SH EXAMPLES
.nf
$ ls
$ ls -l projects
$ ls --tree projects
$ ls -a --tree
.fi
.SH SEE ALSO
help(1), man(1)
