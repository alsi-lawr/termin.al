{"name":"Mathematical Programming System","scopeName":"text.source.mps","patterns":[{"include":"#sections"},{"include":"#constraints"},{"include":"#bounds"},{"include":"#columns"},{"include":"#infinity"},{"include":"#variables"},{"include":"#numbers"},{"include":"#comments"},{"include":"#braces"},{"include":"#parentheses"}],"repository":{"bounds":{"patterns":[{"name":"keyword.bound.mps","match":"(?i)\\b(UP|LO|FX|FR|MI|PL)\\b"}]},"braces":{"patterns":[{"name":"punctuation.definition.block.mps","match":"[{}]"}]},"columns":{"patterns":[{"name":"meta.column.mps","match":"^(\\s{0,2}[A-Za-z0-9]+)\\s+([A-Za-z0-9_]+)\\s+(-?\\d+(\\.\\d+)?|Infinity)\\b","captures":{"1":{"name":"variable.mps"},"2":{"name":"keyword.constraint.mps"},"3":{"name":"constant.numeric.mps"}}}]},"comments":{"patterns":[{"name":"comment.line.mps","begin":"\\*","end":"$"}]},"constraints":{"patterns":[{"name":"keyword.constraint.mps","match":"(?i)\\b(E|L|G|N)\\b"}]},"infinity":{"patterns":[{"name":"constant.language.infinity.mps","match":"(?i)\\bInfinity\\b"}]},"numbers":{"patterns":[{"name":"constant.numeric.mps","match":"\\b\\d+(\\.\\d+)?\\b"}]},"parentheses":{"patterns":[{"name":"punctuation.definition.group.mps","match":"[()]"}]},"sections":{"patterns":[{"name":"keyword.section.mps","match":"(?i)\\b(NAME|ROWS|COLUMNS|RHS|BOUNDS|ENDATA|RANGES)\\b"}]},"variables":{"patterns":[{"name":"variable.mps","match":"\\b[A-Za-z_][A-Za-z0-9_]*\\b"}]}}}
