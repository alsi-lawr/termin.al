{
  "name": "termin.al",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": "1.3.13"
  },
  "scripts": {
    "dev": "bun --smol run vite --mode demo --port 5173 --strictPort",
    "dev:live": "bun --smol run vite --mode live --port 5173 --strictPort",
    "build": "bun run grpc:check && bun run manpages:check && bun run highlighting:check && bun run tsc -b && bun run vite build",
    "grpc:generate": "bun ../scripts/generate-browser-grpc.ts",
    "grpc:check": "bun ../scripts/generate-browser-grpc.ts --check",
    "highlighting:check": "bun ../scripts/generate-highlighting-assets.ts --check",
    "lint": "bun run oxlint .",
    "manpages:generate": "bun ../scripts/generate-manpages.ts",
    "manpages:check": "bun ../scripts/generate-manpages.ts --check",
    "test": "bun test --max-concurrency 1 ./src",
    "preview": "bun --smol run vite preview --port 5175 --strictPort"
  },
  "dependencies": {
    "@protobuf-ts/grpcweb-transport": "2.11.1",
    "@protobuf-ts/runtime": "2.11.1",
    "@protobuf-ts/runtime-rpc": "2.11.1",
    "@tailwindcss/vite": "4.3.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "vscode-oniguruma": "2.0.1",
    "vscode-textmate": "9.3.2",
    "web-tree-sitter": "0.26.11"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "2.11.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "patchedDependencies": {
    "web-tree-sitter@0.26.11": "patches/web-tree-sitter@0.26.11.patch"
  }
}
